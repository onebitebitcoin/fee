# ── 필수 설정 ──────────────────────────────────
POSTGRES_PASSWORD=your-strong-password-here
ADMIN_API_KEY=your-admin-api-key-here

# ── 첫 배포 시 Railway DB 백필 (선택) ──────────
# 설정 시 첫 배포에서 Railway DB → 로컬 DB로 데이터를 자동 복사함
# 이후 재시작에는 crawl_runs 데이터 존재 여부로 자동 skip
# RAILWAY_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── 앱 설정 ────────────────────────────────────
ENVIRONMENT=production
APP_PORT=80
CORS_ORIGINS=https://your-domain.com

# ── 크롤링 설정 ────────────────────────────────
CRAWL_INTERVAL_MINUTES=60
MANUAL_CRAWL_ENABLED=true

# ── 개발 환경 (docker-compose 미사용 시) ────────
# DATABASE_URL=sqlite:///./exchange_fee.db
# PORT=8000
# ENVIRONMENT=development
# VITE_ADMIN_API_KEY=dev-secret-key
