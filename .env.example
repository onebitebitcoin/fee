# ── 개발 환경 (SQLite) ──────────────────────────
DATABASE_URL=sqlite:///./exchange_fee.db
PORT=8000
ENVIRONMENT=development
CORS_ORIGINS=*
CRAWL_INTERVAL_MINUTES=60
MANUAL_CRAWL_ENABLED=true
ADMIN_API_KEY=dev-secret-key
VITE_ADMIN_API_KEY=dev-secret-key

# ── Railway 프로덕션 환경 ────────────────────────
# Railway가 자동으로 제공하는 변수 (직접 설정 불필요):
#   PORT          — 동적 포트 (Dockerfile CMD에서 ${PORT:-8000} 으로 읽음)
#   DATABASE_URL  — Railway PostgreSQL 플러그인 추가 시 자동 주입
#
# Railway 서비스에서 직접 설정해야 하는 변수:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
# ENVIRONMENT=production
# CORS_ORIGINS=https://your-domain.up.railway.app
